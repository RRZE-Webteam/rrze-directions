    "organizationNumber": {
      "type": "string",
      "default": ""
    },
    "addressRoom": {
      "type": "string",
      "default": ""
    },
    "addressFloor": {
      "type": "string",
      "default": ""
    },
    "addressStreet": {
      "type": "string",
      "default": ""
    },
    "addressZip": {
      "type": "string",
      "default": ""
    },
    "addressCity": {
      "type": "string",
      "default": ""
    },
    "addressFormatted": {
      "type": "string",
      "default": ""
    },
    "mapUrl": {
      "type": "string",
      "default": ""
    },
    "mapLatitude": {
      "type": "string",
      "default": ""
