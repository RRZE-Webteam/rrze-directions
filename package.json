{
  "name": "rrze-direction",
  "version": "0.0.61",
  "description": "Arrival descriptions with FAUdir addresses as Gutenberg block.",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": ""
  },
  "textDomain": "rrze-direction",
  "scripts": {
    "build": "wp-scripts build index=./src/index.js view=./src/view.js view-route-map=./src/view-route-map.js --webpack-copy-php && npm run increment-version",
    "increment-version": "node increment-version.js patch",
    "format": "wp-scripts format",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js",
    "packages-update": "wp-scripts packages-update",
    "plugin-zip": "wp-scripts plugin-zip",
    "start": "wp-scripts start index=./src/index.js view=./src/view.js view-route-map=./src/view-route-map.js --webpack-copy-php",
    "build:readme": "node build-readme.js"
  },
  "devDependencies": {
    "@wordpress/scripts": "^30.11.0"
  },
  "dependencies": {
    "leaflet": "^1.7.1"
  }
}