    "directionBikeRoute": {
      "type": "string",
      "default": ""
    },
    "directionCarRoute": {
      "type": "string",
      "default": ""
    },
    "directionTransitRoute": {
      "type": "string",
      "default": ""
    },
    "showDirectionBike": {
      "type": "boolean",
      "default": true
