msgstr "Etwa %1$s km, %2$s Min."

msgid "Walking route from the main station (approximation — use local timetables for buses and trains)."
msgstr "Fußweg ab Hauptbahnhof (Näherung — für Bus und Bahn die örtlichen Fahrpläne nutzen)."

msgid "Fußweg ab Hauptbahnhof (Näherung — für Bus und Bahn bitte aktuelle Fahrpläne nutzen)."
msgstr "Fußweg ab Hauptbahnhof (Näherung — für Bus und Bahn die örtlichen Fahrpläne nutzen)."

